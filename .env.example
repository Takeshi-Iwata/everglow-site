# microCMS 連携用（本番で先方が記事編集できるようにする場合）
# microCMS で「blog」API（リスト形式）を作り、以下を設定してから `node build-blog.js` を実行する。
# 未設定の場合は content/posts.json（デモ用）から生成される。
MICROCMS_SERVICE_DOMAIN=your-service-domain   # 例: everglow → https://everglow.microcms.io
MICROCMS_API_KEY=your-api-key

# 予約システム（Netlify Functions → Supabase）
# Supabase: Settings → API Keys の「Secret key」と Project URL。サーバー専用（公開しない）。
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# 確認メール（任意・Phase 3）。Resend を使う場合のみ設定。未設定ならメール送信はスキップ。
# RESEND_API_KEY=re_xxxxxxxx
# RESERVATION_FROM=Everglow <yoyaku@あなたの認証済みドメイン>
# SALON_EMAIL=salon@example.com   # サロン控えの宛先（任意）
